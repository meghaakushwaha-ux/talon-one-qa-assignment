{
  "name": "talon-one-qa-assignment",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:auth": "cypress run --spec 'cypress/e2e/authentication/**/*.cy.js'",
    "cy:run:purchase": "cypress run --spec 'cypress/e2e/purchase/**/*.cy.js'",
    "report:merge": "mochawesome-merge mochawesome-report/*.json -o mochawesome-report/report.json",
    "report:generate": "marge mochawesome-report/report.json --reportDir mochawesome-report --inline",
    "report": "npm run report:merge && npm run report:generate",
    "lint": "eslint cypress/**/*.js"
  },
